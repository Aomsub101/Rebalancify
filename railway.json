{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "languages": {
        "python": {
          "version": "3.12",
          "poetry": true
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python -m uvicorn api.index:app --host 0.0.0.0 --port $PORT",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}