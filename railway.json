{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "variables": {
    "RAILPACK_PYTHON_VERSION": "3.12"
  },
  "deploy": {
    "startCommand": "uvicorn api.index:app --host 0.0.0.0 --port $PORT",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
