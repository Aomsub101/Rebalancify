# Supabase project URL (found in: Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — NEVER expose this in the browser; server-side only
SUPABASE_SERVICE_ROLE_KEY=

# Supabase JWT secret — used to verify JWTs server-side
SUPABASE_JWT_SECRET=

# 32-byte hex string used to encrypt sensitive data (e.g., broker API keys at rest)
ENCRYPTION_KEY=

# Finnhub API key for real-time stock quotes and news
FINNHUB_API_KEY=

# Financial Modeling Prep (FMP) API key for fundamentals and price data
FMP_API_KEY=
