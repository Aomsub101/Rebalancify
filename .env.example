# =============================================================================
# Rebalancify — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# See docs/development/01-dev-environment.md for setup instructions.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# --- Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Must be a cryptographically random 32-byte hex string. Do NOT use a passphrase.
ENCRYPTION_KEY=[32-byte-random-hex]

# --- External APIs ---
# Add each key as you build the corresponding phase.
FINNHUB_API_KEY=[your-key]          # Required from Phase 1
FMP_API_KEY=[your-key]              # Required from Phase 5
RESEND_API_KEY=[your-key]           # Required from Phase 4
EXCHANGERATE_API_KEY=[your-key]     # Required from Phase 4

# --- Schwab OAuth (register at developer.schwab.com — required for Phase 3) ---
SCHWAB_CLIENT_ID=[your-app-client-id]
SCHWAB_CLIENT_SECRET=[your-app-client-secret]
SCHWAB_REDIRECT_URI=https://[your-domain]/api/auth/schwab/callback

# --- Embedding Provider (required for Phase 8 — AI Research Hub) ---
# Supported values: 'google' (free, recommended) | 'openai' (paid)
# This is a SERVER-SIDE key only. It is NOT the user's LLM key.
EMBEDDING_PROVIDER=google
EMBEDDING_API_KEY=[your-google-ai-studio-key-or-openai-key]

# Vercel Cron Job authentication secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_SECRET=[your-random-32-byte-hex]
